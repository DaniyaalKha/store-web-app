{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["index.ts", "prisma/seed.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
